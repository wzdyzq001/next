/* ============================================================
 * AI 助手入口层样式
 * ============================================================ */

/* 列表页 AI 入口按钮 */
.oc-list-ai-btn {
  position: relative;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.oc-list-ai-btn:active {
  transform: scale(0.95);
}

.oc-list-ai-btn .ai-entry-red-dot {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 8px;
  height: 8px;
  background: #ff4d4f;
  border-radius: 50%;
  border: 1.5px solid #fff;
  z-index: 2;
  animation: ai-dot-pulse 2s ease-in-out infinite;
}

@keyframes ai-dot-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.8;
  }
}

/* 详情页悬浮 AI 入口按钮 */
.ai-detail-entry-btn {
  position: fixed;
  left: 16px;
  bottom: 80px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #f0fdff 50%, #d6f7ff 100%);
  box-shadow: 0 4px 20px rgba(0, 176, 255, 0.25), 0 2px 8px rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 100;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 2px solid rgba(79, 195, 247, 0.3);
}

.ai-detail-entry-btn:active {
  transform: scale(0.95);
}

.ai-detail-entry-btn .ai-entry-icon {
  width: 36px;
  height: 36px;
}

.ai-detail-entry-btn .ai-entry-red-dot {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 12px;
  height: 12px;
  background: #ff4d4f;
  border-radius: 50%;
  border: 2px solid #fff;
  z-index: 2;
  animation: ai-dot-pulse 2s ease-in-out infinite;
}

.ai-detail-entry-btn .ai-entry-label {
  position: absolute;
  bottom: -22px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 11px;
  color: #4FC3F7;
  white-space: nowrap;
  font-weight: 500;
}

/* ============================================================
 * AI 助手浮层样式
 * ============================================================ */

.ai-overlay-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  pointer-events: none;
}

.ai-overlay-mask.open {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.ai-overlay-panel {
  position: fixed;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%) translateY(100%);
  width: 100%;
  max-width: var(--mobile-page-width);
  background: #f7f8fa;
  border-radius: 20px 20px 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease-out;
  touch-action: none;
  will-change: transform;
}

.ai-overlay-mask.open .ai-overlay-panel {
  transform: translateX(-50%) translateY(0);
}

.ai-overlay-panel.minimized {
  height: 90%;
}

.ai-overlay-panel.fullscreen {
  height: 100%;
  border-radius: 0;
}

.ai-overlay-grabber {
  width: 40px;
  height: 4px;
  background: #d9dbe0;
  border-radius: 2px;
  margin: 8px auto 0;
  flex-shrink: 0;
}

/* 头部区域 */
.ai-overlay-header {
  display: flex;
  align-items: center;
  padding: 12px 16px 12px;
  background: #ffffff;
  border-bottom: 1px solid #f0f1f5;
  flex-shrink: 0;
}

.ai-overlay-avatar {
  margin-right: 12px;
}

.ai-avatar-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #08223D, #0D4A75);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(13, 74, 117, 0.2);
}

.ai-overlay-title-group {
  flex: 1;
  min-width: 0;
}

.ai-overlay-title {
  font-size: 17px;
  font-weight: 600;
  color: #1f2329;
  line-height: 1.3;
}

.ai-overlay-subtitle {
  font-size: 12px;
  color: #86909c;
  margin-top: 2px;
}

.ai-overlay-actions {
  display: flex;
  align-items: center;
  gap: 4px;
}

.ai-overlay-action-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: transparent;
  color: #4e5969;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.ai-overlay-action-btn:active {
  background: #f2f3f5;
}

.ai-overlay-action-btn.close-btn:active {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 消息区域 */
.ai-overlay-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 0;
  -webkit-overflow-scrolling: touch;
}

.ai-message-list {
  padding: 0 16px;
}

.ai-message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16px;
  gap: 8px;
}

.ai-message.user {
  flex-direction: row-reverse;
}

.ai-message-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.ai-message-avatar.user {
  background: linear-gradient(135deg, #165dff, #4080ff);
  color: #fff;
}

.ai-message-bubble {
  max-width: 75%;
  padding: 10px 14px;
  border-radius: 16px;
  word-wrap: break-word;
  word-break: break-word;
}

.ai-message.assistant .ai-message-bubble {
  background: #ffffff;
  border: 1px solid #eef0f3;
  border-top-left-radius: 4px;
}

.ai-message.user .ai-message-bubble {
  background: linear-gradient(135deg, #165dff, #4080ff);
  color: #ffffff;
  border-top-right-radius: 4px;
}

.ai-message-text {
  font-size: 15px;
  line-height: 1.6;
}

/* 打字指示器 */
.ai-typing-indicator {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 2px;
}

.ai-typing-indicator span {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #86909c;
  animation: ai-typing-bounce 1.4s ease-in-out infinite;
}

.ai-typing-indicator span:nth-child(2) {
  animation-delay: 0.2s;
}

.ai-typing-indicator span:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes ai-typing-bounce {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-6px);
    opacity: 1;
  }
}

/* 底部输入区 */
.ai-overlay-footer {
  background: #ffffff;
  border-top: 1px solid #f0f1f5;
  padding: 8px 16px calc(8px + env(safe-area-inset-bottom, 0px));
  flex-shrink: 0;
}

.ai-order-selector {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  margin-bottom: 8px;
  background: #f2f3f5;
  border-radius: 12px;
  font-size: 13px;
  color: #4e5969;
  cursor: pointer;
}

.ai-order-selector-icon {
  display: flex;
  color: #165dff;
}

.ai-order-selector-text {
  flex: 1;
}

.ai-order-selector-arrow {
  display: flex;
  color: #86909c;
}

.ai-input-area {
  display: flex;
  align-items: center;
  gap: 8px;
}

.ai-voice-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: #f2f3f5;
  color: #4e5969;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s ease;
}

.ai-voice-btn:active {
  background: #e5e6eb;
}

.ai-voice-btn.listening {
  background: #ff4d4f;
  color: #ffffff;
  animation: ai-voice-pulse 1s ease-in-out infinite;
}

@keyframes ai-voice-pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 77, 79, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 8px rgba(255, 77, 79, 0);
  }
}

.ai-input {
  flex: 1;
  height: 36px;
  padding: 0 14px;
  border: 1px solid #e5e6eb;
  border-radius: 18px;
  background: #f7f8fa;
  font-size: 15px;
  color: #1f2329;
  outline: none;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.ai-input:focus {
  border-color: #165dff;
  background: #ffffff;
}

.ai-input::placeholder {
  color: #a9aeb8;
}

.ai-voice-input-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.ai-hold-to-talk {
  width: 100%;
  height: 36px;
  border: 1px solid #e5e6eb;
  border-radius: 18px;
  background: #f7f8fa;
  font-size: 15px;
  color: #4e5969;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  user-select: none;
  transition: all 0.2s ease;
}

.ai-hold-to-talk:active {
  background: #e5e6eb;
}

.ai-hold-to-talk.listening {
  background: #e8f3ff;
  border-color: #165dff;
  color: #165dff;
  font-weight: 500;
}

.ai-volume-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 32px;
}

.ai-volume-bar {
  width: 3px;
  border-radius: 2px;
  background: linear-gradient(to top, #165dff, #4080ff);
  transition: height 0.08s ease-out, opacity 0.08s ease-out;
}

.ai-voice-error {
  font-size: 12px;
  color: #f53f3f;
  text-align: center;
  line-height: 1.4;
}

/* ============================================================
 * 加号按钮 & 已选订单
 * ============================================================ */

.ai-add-order-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: #f2f3f5;
  color: #4e5969;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s ease;
}

.ai-add-order-btn:active {
  background: #e5e6eb;
}

.ai-selected-order {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  margin-bottom: 8px;
  background: #f2f3f5;
  border-radius: 12px;
  gap: 10px;
}

.ai-selected-order-info {
  flex: 1;
  min-width: 0;
}

.ai-selected-order-merchant {
  font-size: 13px;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ai-selected-order-product {
  font-size: 12px;
  color: #86909c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ai-selected-order-remove {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: none;
  background: transparent;
  color: #86909c;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s ease, color 0.2s ease;
}

.ai-selected-order-remove:active {
  background: #e5e6eb;
  color: #ff4d4f;
}

/* ============================================================
 * 订单选择浮层
 * ============================================================ */

.ai-order-selector-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  pointer-events: none;
}

.ai-order-selector-mask.open {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.ai-order-selector-panel {
  position: fixed;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%) translateY(100%);
  width: 100%;
  max-width: var(--mobile-page-width);
  height: 85%;
  background: #f7f8fa;
  border-radius: 20px 20px 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease-out;
  will-change: transform;
}

.ai-order-selector-mask.open .ai-order-selector-panel {
  transform: translateX(-50%) translateY(0);
}

.ai-order-selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  background: #ffffff;
  border-bottom: 1px solid #f0f1f5;
  flex-shrink: 0;
}

.ai-order-selector-title {
  font-size: 17px;
  font-weight: 600;
  color: #1f2329;
}

.ai-order-selector-close {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: transparent;
  color: #4e5969;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.ai-order-selector-close:active {
  background: #f2f3f5;
  color: #ff4d4f;
}

.ai-order-selector-tabs {
  display: flex;
  gap: 0;
  padding: 0 12px;
  background: #ffffff;
  border-bottom: 1px solid #f0f1f5;
  overflow-x: auto;
  flex-shrink: 0;
  -webkit-overflow-scrolling: touch;
}

.ai-order-selector-tabs::-webkit-scrollbar {
  display: none;
}

.ai-order-selector-tab {
  padding: 12px 14px;
  font-size: 14px;
  color: #4e5969;
  background: transparent;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  position: relative;
  transition: color 0.2s ease;
  flex-shrink: 0;
}

.ai-order-selector-tab:active {
  opacity: 0.7;
}

.ai-order-selector-tab.active {
  color: #165dff;
  font-weight: 600;
}

.ai-order-selector-tab.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 20px;
  height: 3px;
  background: #165dff;
  border-radius: 2px;
}

.ai-order-selector-list {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  -webkit-overflow-scrolling: touch;
}

.ai-order-selector-empty {
  text-align: center;
  padding: 60px 20px;
  color: #86909c;
  font-size: 14px;
}
